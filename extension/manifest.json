{
  "manifest_version": 3,
  "name": "page2md",
  "version": "1.0.0",
  "description": "Convert the current page to Markdown, including logged-in content.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "page2md",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://amm-page2md.vercel.app/*", "http://localhost:3000/*"],
      "js": ["history-bridge.js"],
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["https://amm-page2md.vercel.app/*", "http://localhost:3000/*"],
  "permissions": ["activeTab", "scripting", "storage"]
}
